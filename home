<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
  // --- RESEÑAS INICIALES ---
  const resenasIniciales = [
    { nombre: "Valentina Rodríguez", titulo: "Una experiencia que cambia la vida", texto: "Fui con mi pareja sin saber muy bien qué esperar, y volvimos completamente transformados. La guía conocía cada historia de cada piedra. El atardecer en el volcán fue lo más hermoso que vimos en nuestra vida.", estrellas: 5, fecha: "Noviembre 2024" },
    { nombre: "Marcos Fernández", titulo: "El mejor guía de la Puna", texto: "Llevamos a toda la familia, incluyendo niños de 8 y 10 años. Adaptaron perfectamente el ritmo y los chicos quedaron fascinados con los flamencos en Laguna Blanca. La comida que nos prepararon era riquísima. Volvemos sin dudas.", estrellas: 5, fecha: "Octubre 2024" },
    { nombre: "Ana Quiroga", titulo: "El salar: paisaje de otro planeta", texto: "Hice la excursión al Salar de Antofalla y quedé sin palabras. Cuatro horas manejando por huellas, pero cada kilómetro valió la pena. El guía contó la historia geológica del lugar de una manera apasionante. Muy recomendable.", estrellas: 5, fecha: "Septiembre 2024" }
  ];

  let resenas = [...resenasIniciales];
  let ratingSeleccionado = 0;

  function estrellasHTML(n) {
    return '★'.repeat(n) + '☆'.repeat(5 - n);
  }

  function renderResenas() {
    const lista = document.getElementById('resenas-lista');
    lista.innerHTML = '';
    [...resenas].reverse().forEach(r => {
      const card = document.createElement('div');
      card.className = 'resena-card';
      card.innerHTML = `
        <div class="resena-header">
          <div>
            <div class="resena-autor">${r.nombre}</div>
            <div class="resena-fecha">${r.fecha}</div>
          </div>
          <div class="resena-stars">${estrellasHTML(r.estrellas)}</div>
        </div>
        <div style="font-weight: 500; font-size: 0.9rem; margin-bottom: 0.4rem;">${r.titulo}</div>
        <div class="resena-texto">${r.texto}</div>
      `;
      lista.appendChild(card);
    });

    const prom = resenas.reduce((a, r) => a + r.estrellas, 0) / resenas.length;
    document.getElementById('prom-num').textContent = prom.toFixed(1);
    document.getElementById('prom-stars').textContent = estrellasHTML(Math.round(prom));
    document.getElementById('total-reviews').textContent = `${resenas.length} reseña${resenas.length !== 1 ? 's' : ''}`;
  }

  // Star picker
  const picker = document.getElementById('star-picker');
  picker.querySelectorAll('span').forEach(s => {
    s.addEventListener('click', () => {
      ratingSeleccionado = parseInt(s.dataset.val);
      picker.querySelectorAll('span').forEach(x => {
        x.classList.toggle('active', parseInt(x.dataset.val) <= ratingSeleccionado);
      });
    });
    s.addEventListener('mouseenter', () => {
      const val = parseInt(s.dataset.val);
      picker.querySelectorAll('span').forEach(x => {
        x.classList.toggle('active', parseInt(x.dataset.val) <= val);
      });
    });
    s.addEventListener('mouseleave', () => {
      picker.querySelectorAll('span').forEach(x => {
        x.classList.toggle('active', parseInt(x.dataset.val) <= ratingSeleccionado);
      });
    });
  });

  function mostrarToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('visible');
    setTimeout(() => t.classList.remove('visible'), 3500);
  }

  function publicarResena() {
    const nombre = document.getElementById('r-nombre').value.trim();
    const titulo = document.getElementById('r-titulo').value.trim();
    const texto = document.getElementById('r-texto').value.trim();
    if (!nombre || !texto || ratingSeleccionado === 0) {
      mostrarToast('Por favor completá tu nombre, calificación y comentario.');
      return;
    }
    const meses = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
    const hoy = new Date();
    resenas.push({
      nombre,
      titulo: titulo || 'Mi experiencia',
      texto,
      estrellas: ratingSeleccionado,
      fecha: `${meses[hoy.getMonth()]} ${hoy.getFullYear()}`
    });
    renderResenas();
    document.getElementById('r-nombre').value = '';
    document.getElementById('r-titulo').value = '';
    document.getElementById('r-texto').value = '';
    ratingSeleccionado = 0;
    picker.querySelectorAll('span').forEach(x => x.classList.remove('active'));
    mostrarToast('¡Gracias por compartir tu experiencia! 🙏');
    document.getElementById('resenas-lista').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function enviarConsulta() {
    const nombre = document.getElementById('c-nombre').value.trim();
    const email = document.getElementById('c-email').value.trim();
    const msg = document.getElementById('c-mensaje').value.trim();
    if (!nombre || !email || !msg) {
      mostrarToast('Por favor completá todos los campos.');
      return;
    }
    document.getElementById('c-nombre').value = '';
    document.getElementById('c-email').value = '';
    document.getElementById('c-excursion').value = '';
    document.getElementById('c-mensaje').value = '';
    mostrarToast('¡Consulta enviada! Te respondemos en menos de 24hs. 🙌');
  }

  renderResenas();
</script>
